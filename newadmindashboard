  const ADMIN_EDGE_URL=`${SUPABASE_URL}/functions/v1/admin-list-pdfs`;
  async function edgeRequest(action, body=null) {
    const { data:{ session } }=await window.supabase.auth.getSession();
    if (!session) throw new Error("Not authenticated");
    const url=`${ADMIN_EDGE_URL}?action=${action}`;
    const options={ method:body?"POST":"GET", headers:{ "Authorization":`Bearer ${session.access_token}` } };
    if (body instanceof FormData){ options.body=body; } else if (body){ options.headers["Content-Type"]="application/json"; options.body=JSON.stringify(body); }
    const res=await fetch(url,options);
    if (!res.ok){ const err=await res.json().catch(()=>({error:`HTTP ${res.status}`})); throw new Error(err.error||`HTTP ${res.status}`); }
    return res.json();
  }
  async function loadSheetMusic() {
    const grid=document.getElementById('pdfGrid');
    grid.innerHTML='<div class="loading"><div class="spinner"></div>Loading PDFs...</div>';
    try { const result=await edgeRequest("list"); allPDFs=result.files||[]; allPDFs.length?renderPDFs(allPDFs):(grid.innerHTML='<div class="empty-state"><div class="empty-state-icon">📄</div><p>No PDFs yet</p></div>'); } catch(e){ grid.innerHTML=`<div class="error-message">Error: ${e.message}</div>`; }
  }
  function renderPDFs(pdfs) {
    const grid=document.getElementById('pdfGrid');
    if (!pdfs.length){ grid.innerHTML='<div class="empty-state"><div class="empty-state-icon">📄</div><p>No PDFs uploaded yet</p></div>'; return; }
    grid.innerHTML=pdfs.map(pdf=>`<div class="pdf-item"><div class="pdf-icon">📄</div><div class="pdf-name">${pdf.name}</div><div style="font-size:12px;color:var(--muted);margin-bottom:12px">${pdf.metadata?.size?(pdf.metadata.size/1024).toFixed(1)+' KB':'Unknown size'}</div><div class="pdf-actions"><button class="btn-view" onclick="viewPDF('${pdf.name}')">👁️ View</button><button class="btn-delete" onclick="deletePDF('${pdf.name}')">🗑️ Delete</button></div></div>`).join('');
  }
  function filterPDFs() { const q=document.getElementById('pdfSearch').value.toLowerCase(); renderPDFs(allPDFs.filter(pdf=>pdf.name.toLowerCase().includes(q))); }
  async function viewPDF(filename) { try { const result=await edgeRequest("view",{filename}); window.open(result.url,'_blank'); } catch(e){ alert('❌ Error viewing PDF: '+e.message); } }
  async function deletePDF(filename) {
    if (!confirm(`Delete "${filename}"?\nUsers who purchased this song can no longer download it.`)) return;
    try { await edgeRequest("delete",{filename}); alert('✅ PDF deleted!'); await loadSheetMusic(); } catch(e){ alert('❌ Error: '+e.message); }
  }
  async function uploadPDFs(event) {
    const files=Array.from(event.target.files); if (!files.length) return;
    const progress=document.getElementById('uploadProgress'), status=document.getElementById('uploadStatus'), bar=document.getElementById('uploadBar');
    progress.classList.remove('hidden'); let uploaded=0;
    for (const file of files) {
      if (!file.name.endsWith('.pdf')){ alert(`⚠️ Skipping "${file.name}"`); continue; }
      try { status.textContent=`Uploading ${uploaded+1}/${files.length}: ${file.name}`; bar.style.width=`${(uploaded/files.length)*100}%`; const fd=new FormData(); fd.append("file",file); fd.append("filename",file.name); await edgeRequest("upload",fd); uploaded++; } catch(e){ alert(`❌ Error uploading "${file.name}": ${e.message}`); }
    }
    bar.style.width='100%'; status.textContent=`✅ Uploaded ${uploaded}/${files.length} files!`;
    setTimeout(()=>{ progress.classList.add('hidden'); bar.style.width='0%'; event.target.value=''; },2000);
    await loadSheetMusic();
  }

