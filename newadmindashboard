      };
      if (liveExchangeRates?.USD) {
        const inrPerUsd=1/liveExchangeRates.USD;
        const er={USD:1,INR:parseFloat(inrPerUsd.toFixed(2))};
        RATE_CURRENCIES.forEach(code=>{ if (code!=='USD'&&liveExchangeRates[code]!=null) er[code]=parseFloat((liveExchangeRates[code]/liveExchangeRates.USD).toFixed(4)); });
