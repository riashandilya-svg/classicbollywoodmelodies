  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script>
  // ═══════════════════════════════════════════════════════
  // CONFIGURATION — update these if they change
  // ═══════════════════════════════════════════════════════
  const SUPABASE_URL      = "https://lyqpxcilniqzurevetae.supabase.co";
  const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imx5cXB4Y2lsbmlxenVyZXZldGFlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Njk1NDAyMTQsImV4cCI6MjA4NTExNjIxNH0.40ZbAatkMBFHacQGCpiNYpjcKQoZik-Xvqx3bG46x7c";
  const ADMIN_EMAILS      = ["riaomshandilya@gmail.com", "riashandilya@gmail.com"];

  // Edge function base — constructed automatically from SUPABASE_URL
  const EDGE_BASE = `${SUPABASE_URL}/functions/v1`;

  window.supabase = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  // ── Global data stores ──────────────────────────────────
  let allUsers = [], allCodes = [], allPurchases = [], allBundles = [];
  let allSubscriptions = [], allFeedback = [], allCourseProgress = [], allPDFs = [];
  let savedExchangeRates = null, liveExchangeRates = null;
  let userToDelete = null, currentManageUser = null, songToRemove = null, songToGrant = null;
  let subToCancel = null;

  const CURRENCY_SYMBOLS = { INR:'₹',USD:'$',GBP:'£',EUR:'€',CAD:'CA$',AUD:'A$',JPY:'¥' };
  const RATE_CURRENCIES  = ['USD','GBP','EUR','CAD','AUD','JPY'];

  // ═══════════════════════════════════════════════════════
  // HELPERS
  // ═══════════════════════════════════════════════════════
  function escHTML(s) {
    return String(s ?? '').replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;");
  }
  function userInfoHTML(name, email) {
    return `<div class="user-info"><span class="user-name">${escHTML(name||'N/A')}</span><span class="user-email">${escHTML(email||'N/A')}</span></div>`;
  }
  function getProfile(userId) { return allUsers.find(u => u.id === userId); }
  function getSongsForUser(uid) { return allPurchases.filter(p => p.user_id===uid && p.song_id!=='pack:5').map(p=>p.song_id); }
  function getBundleCountForUser(uid) { return allBundles.filter(b => b.user_id===uid).length; }
  function formatAmount(amount, currency='INR') {
    if (!amount) return 'N/A';
    const sym = CURRENCY_SYMBOLS[currency]||currency;
    return `${sym}${(amount/100).toFixed(['JPY','KRW'].includes(currency)?0:2)}`;
  }
  function convertToINR(amount, currency) {
    if (!amount) return 0;
    if (!currency||currency==='INR') return amount;
    if (!savedExchangeRates?.INR) {
      const fb={USD:1,INR:84,GBP:0.79,EUR:0.92,CAD:1.35,AUD:1.52,JPY:148};
      return Math.round(amount*(fb.INR/(fb[currency]||1)));
    }
    const rateC=savedExchangeRates[currency];
    if (!rateC) return amount;
    return Math.round(amount*(savedExchangeRates.INR/rateC));
  }

  // Edge function helper (uses current session token)
  async function edgeCall(fnName, body={}) {
    const { data:{ session } } = await window.supabase.auth.getSession();
    if (!session) throw new Error("Not authenticated");
    const res = await fetch(`${EDGE_BASE}/${fnName}`, {
      method: 'POST',
      headers: { 'Content-Type':'application/json', 'Authorization':`Bearer ${session.access_token}` },
      body: JSON.stringify(body)
    });
    const json = await res.json();
    if (!res.ok) throw new Error(json.error || json.details || `HTTP ${res.status}`);
    return json;
  }

  // ═══════════════════════════════════════════════════════
  // AUTH + INIT
  // ═══════════════════════════════════════════════════════
  async function checkAdminAccess() {
    try {
      const { data:{ session }, error } = await window.supabase.auth.getSession();
      if (error||!session) { document.getElementById('authCheck').innerHTML='<p style="color:var(--error)">Access Denied: Not logged in</p>'; return; }
      if (!ADMIN_EMAILS.includes(session.user.email)) { document.getElementById('authCheck').innerHTML='<p style="color:var(--error)">⛔ Access Denied: Not an admin</p>'; return; }
      document.getElementById('authCheck').classList.add('hidden');
      document.getElementById('adminContent').classList.remove('hidden');
      await Promise.all([loadPurchasesData(), loadBundlesData(), loadSavedRates(), loadSubscriptionsData()]);
      loadStats(); loadUsers(); loadCodes(); updateRevenueDisplay();
      updateSortHeaders('purchases'); renderPurchases(sortArray(allPurchases,'purchases'));
      updateSortHeaders('bundles'); renderBundles(sortArray(allBundles,'bundles'));
      initSortHeaders();
    } catch(err) { console.error(err); document.getElementById('authCheck').innerHTML='<p style="color:var(--error)">An error occurred</p>'; }
  }

  async function loadStats() {
    try {
      const { data:profiles } = await window.supabase.from('profiles').select('id,email,is_book_owner');
      const nonAdmin = (profiles||[]).filter(p=>!ADMIN_EMAILS.includes(p.email));
      document.getElementById('totalUsers').textContent = nonAdmin.length;
      document.getElementById('bookOwners').textContent = nonAdmin.filter(p=>p.is_book_owner).length;
      const { count:totalCodes } = await window.supabase.from('book_verification_codes').select('*',{count:'exact',head:true});
      const { count:codesUsed } = await window.supabase.from('book_verification_codes').select('*',{count:'exact',head:true}).eq('is_used',true);
      const used=codesUsed||0, left=(totalCodes||0)-used;
      document.getElementById('codesUsed').textContent=used;
      document.getElementById('codesLeft').textContent=left;
      document.getElementById('codesLeft').style.color=left<=2?'var(--error)':'var(--warning)';
      const adminIds=(profiles||[]).filter(p=>ADMIN_EMAILS.includes(p.email)).map(p=>p.id);
      document.getElementById('totalPurchases').textContent=(allPurchases||[]).filter(p=>!adminIds.includes(p.user_id)).length;
      document.getElementById('bundlesPurchased').textContent=(allBundles||[]).filter(b=>!adminIds.includes(b.user_id)).length;
      const activeSubs=(allSubscriptions||[]).filter(s=>s.status==='active').length;
      document.getElementById('activeSubsCount').textContent=activeSubs;
    } catch(e){ console.error('Stats error:',e); }
  }

  // ═══════════════════════════════════════════════════════
  // REVENUE
  // ═══════════════════════════════════════════════════════
  function updateRevenueDisplay() {
    const period=document.getElementById('revenuePeriod').value;
    document.getElementById('customDateRange').classList.toggle('hidden', period!=='custom');
    calculateRevenue();
  }
  function calculateRevenue() {
    const period=document.getElementById('revenuePeriod').value;
    const now=new Date(); let startDate,endDate;
    if (period==='today') { startDate=new Date(now.getFullYear(),now.getMonth(),now.getDate()); endDate=new Date(now.getFullYear(),now.getMonth(),now.getDate(),23,59,59,999); }
    else if (period==='month') { startDate=new Date(now.getFullYear(),now.getMonth(),1); endDate=now; }
    else if (period==='90days') { startDate=new Date(now); startDate.setDate(startDate.getDate()-90); endDate=now; }
    else if (period==='year') { startDate=new Date(now.getFullYear(),0,1); endDate=now; }
    else if (period==='custom') {
      const s=document.getElementById('startDate').value, e=document.getElementById('endDate').value;
      if (!s||!e) return;
      startDate=new Date(s); endDate=new Date(e); endDate.setHours(23,59,59,999);
    }
    const filtered=allPurchases.filter(p=>{ const d=new Date(p.created_at); return d>=startDate&&d<=endDate; });
    let total=0; filtered.forEach(p=>{ total+=convertToINR(p.amount||0,p.currency||'INR'); });
    document.getElementById('revenueINR').textContent=formatAmount(total,'INR');
    document.getElementById('revenueTransactions').textContent=filtered.length;
  }
