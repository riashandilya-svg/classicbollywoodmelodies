        monthlyInfo.innerHTML=`Current active plan: <strong>₹${(monthly.amount/100).toFixed(0)}/mo</strong><br>Razorpay Plan ID: <span class="code-display" style="font-size:11px">${monthly.razorpay_plan_id}</span>`;
