  async function fetchLiveRates() {
    const loading=document.getElementById('ratesLoading'), container=document.getElementById('ratesGridContainer'), errEl=document.getElementById('ratesError'), gridEl=document.getElementById('ratesGridEl'), statusEl=document.getElementById('ratesStatus');
    loading.style.display='block'; container.classList.add('hidden'); errEl.classList.add('hidden'); errEl.textContent='';
    try {
      const res=await fetch(`https://api.frankfurter.dev/v1/latest?base=INR&symbols=${RATE_CURRENCIES.join(',')}`);
      if (!res.ok) throw new Error(`Frankfurter ${res.status}`);
      const json=await res.json(); liveExchangeRates=json.rates;
      gridEl.innerHTML=RATE_CURRENCIES.map(code=>{ const val=json.rates[code]; if (val==null) return ''; const dec=val<0.01?6:val<1?4:val>=100?1:3; return `<div class="rate-chip"><div class="rate-code">${code}</div><div class="rate-val">${val.toFixed(dec)}</div><div class="rate-label">1 INR = ${val.toFixed(dec)} ${code}<br>1 ${code} = ₹${(1/val).toFixed(2)}</div></div>`; }).join('');
      loading.style.display='none'; container.classList.remove('hidden');
      statusEl.innerHTML=`<span class="live-dot"></span>Live rates as of <strong>${json.date}</strong>`;
    } catch(e){ loading.style.display='none'; errEl.classList.remove('hidden'); errEl.textContent='❌ Failed to fetch rates: '+e.message; liveExchangeRates=null; }
  }

